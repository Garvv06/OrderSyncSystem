# MFOI Database Configuration
# Choose ONE of the following options:

# ==================================================
# OPTION 1: Supabase (Free tier - may pause)
# ==================================================
# VITE_SUPABASE_URL=your_supabase_project_url
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==================================================
# OPTION 2: Neon PostgreSQL (FREE FOREVER - Recommended)
# ==================================================
# Get your connection string from: https://neon.tech
# Example: postgresql://user:pass@ep-cool-meadow-12345.us-east-2.aws.neon.tech/dbname?sslmode=require
VITE_NEON_CONNECTION_STRING=your_neon_connection_string_here

# ==================================================
# OPTION 3: LocalStorage Only (No cloud sync)
# ==================================================
# Leave all variables above empty to use localStorage only
# Data stays on your browser - 100% free, works offline
